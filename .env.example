# Porta em que o servidor do cliente vai ouvir
PORT=8080

# URL do servidor TableRise (backend Express + Socket.IO)
BACKEND_URL=http://localhost:3000

# Origens externas permitidas para CORS (separadas por vírgula).
# Deixe vazio para aceitar apenas same-origin (recomendado em produção).
# Exemplo: https://meusite.com,https://outro.com
ALLOWED_ORIGINS=
